import json
import sys
import tomllib
from pathlib import Path

from openhands.sdk import LLM, LLMSummarizingCondenser
from openhands.sdk.llm.message import Message as SDKMessage
from openhands_cli.entrypoint import main
from openhands_cli.stores.agent_store import AgentStore


def load_config_model() -> str:
    config_path = Path.home() / ".openhands/config.toml"
    if config_path.exists():
        with config_path.open("rb") as f:
            data = tomllib.load(f)
        model = data.get("llm", {}).get("model")
        if isinstance(model, str) and model:
            return model
    return "openai/gpt-5.2-codex"


def normalize_codex_model(model: str) -> str:
    model = model.strip()
    if model.startswith("openai/"):
        model = model.removeprefix("openai/")
    if model.startswith("litellm_proxy/"):
        model = model.removeprefix("litellm_proxy/")
    return model


def load_oauth_payload() -> tuple[str, str | None]:
    creds_path = Path.home() / ".openhands/auth/openai_oauth.json"
    if not creds_path.exists():
        print("Error: Credentials not found. Please run `uv run login.py` first.")
        sys.exit(1)

    with creds_path.open() as f:
        creds = json.load(f)

    access_token = creds.get("access_token", "")
    if not access_token:
        print("Error: access_token not found in ~/.openhands/auth/openai_oauth.json")
        sys.exit(1)

    try:
        import base64

        payload = access_token.split(".")[1]
        payload += "=" * (-len(payload) % 4)
        decoded = json.loads(base64.urlsafe_b64decode(payload))
        account_id = (
            decoded.get("https://api.openai.com/auth", {}).get("chatgpt_account_id")
        )
        return access_token, account_id
    except Exception:
        return access_token, None


def build_subscription_llm(
    access_token: str, account_id: str | None, model: str, usage_id: str
):
    extra_headers = {
        "originator": "codex_cli_rs",
        "OpenAI-Beta": "responses=experimental",
    }
    if account_id:
        extra_headers["chatgpt-account-id"] = account_id

    llm = LLM(
        model=f"openai/{model}",
        base_url="https://chatgpt.com/backend-api/codex",
        api_key=access_token,
        extra_headers=extra_headers,
        litellm_extra_body={"store": False},
        temperature=None,
        max_output_tokens=None,
        stream=True,
        usage_id=usage_id,
        reasoning_effort="high",
        drop_params=True,
        modify_params=True,
        caching_prompt=False,
        native_tool_calling=True,
        prompt_cache_retention=None,
        reasoning_summary=None,
        enable_encrypted_reasoning=False,
        extended_thinking_budget=None,
        top_p=None,
        seed=None,
    )
    llm._is_subscription = True
    llm.max_output_tokens = None
    llm.temperature = None
    llm.prompt_cache_retention = None
    return llm


def patch_agent_store() -> None:
    desired_model = normalize_codex_model(load_config_model())
    access_token, account_id = load_oauth_payload()
    original_load_from_disk = AgentStore.load_from_disk
    original_to_responses_dict = SDKMessage.to_responses_dict

    def patched_to_responses_dict(self, *, vision_enabled: bool):
        # Subscription transport is stateless; replaying prior reasoning items with
        # server-issued rs_* ids causes invalid input references on subsequent turns.
        if self.role == "assistant" and self.responses_reasoning_item is not None:
            original_reasoning_item = self.responses_reasoning_item
            self.responses_reasoning_item = None
            try:
                return original_to_responses_dict(self, vision_enabled=vision_enabled)
            finally:
                self.responses_reasoning_item = original_reasoning_item
        return original_to_responses_dict(self, vision_enabled=vision_enabled)

    SDKMessage.to_responses_dict = patched_to_responses_dict

    def patched_load_from_disk(self):
        agent = original_load_from_disk(self)
        if agent is None:
            return None

        agent_llm = build_subscription_llm(
            access_token, account_id, desired_model, "agent"
        )
        condenser = agent.condenser
        if condenser and isinstance(condenser, LLMSummarizingCondenser):
            condenser_llm = build_subscription_llm(
                access_token, account_id, desired_model, "condenser"
            )
            condenser = condenser.model_copy(update={"llm": condenser_llm})

        return agent.model_copy(update={"llm": agent_llm, "condenser": condenser})

    AgentStore.load_from_disk = patched_load_from_disk

    print(
        f"Using ChatGPT subscription transport for openai/{desired_model} via "
        "https://chatgpt.com/backend-api/codex"
    )
    if account_id:
        print(f"Loaded Codex credentials for Account ID: {account_id}")


if __name__ == "__main__":
    patch_agent_store()
    sys.exit(main())
